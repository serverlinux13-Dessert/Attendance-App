APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
TRUST_PROXY=1
# Use 1 when serving over HTTPS; set 0 for HTTP-only LAN access.
SESSION_COOKIE_SECURE=1

# Optional office network restriction
REQUIRE_OFFICE_NETWORK=0
# Allow ADMIN users to access dashboard/APIs from any IP
ALLOW_ADMIN_FROM_ANYWHERE=1
# Legacy single subnet/IP (optional)
ALLOWED_SUBNET=
# Preferred: comma-separated list of allowed IPs/subnets
# Example: ALLOWED_SUBNETS=192.168.1.0/24,203.0.113.10/32,198.51.100.20/32
ALLOWED_SUBNETS=

# Optional if you run without nginx reverse proxy
PORT=8000
